# Template only — the server loads backend/.env (not this file). Copy to .env and fill in values. Never commit .env.

PORT=3001
# Single origin or leave unset to use app defaults (localhost Vite ports).
# CORS_ORIGIN=http://localhost:5173

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=quiz_app

# Google AI Studio — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional Gemini tuning (see services/aiService.js)
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_CONTEXT_MAX_CHARS=3200
# GEMINI_QUOTA_RETRY_ROUNDS=4

# Required for auth (min 16 chars). Example: openssl rand -hex 32
JWT_SECRET=
# JWT_EXPIRES_IN=7d
